---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/hero.astro';
---

<Layout>
	<main id="home" class="home-main" tabindex="-1">
		<Hero />
	</main>

	<section id="work" class="section-placeholder" aria-hidden="true" />
	<section id="about" class="section-placeholder" aria-hidden="true" />
</Layout>

<style is:global>
	.home-main {
		position: relative;
		z-index: 4;
		width: 100%;
		height: 100vh;
		height: 100svh;
		min-height: 100vh;
		min-height: 100svh;
		max-height: 100vh;
		max-height: 100svh;
		overflow: hidden;
	}

	.section-placeholder {
		min-height: 50vh;
	}
</style>
