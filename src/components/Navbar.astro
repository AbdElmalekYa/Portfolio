---
const links = [
  { href: "#home", label: "Home" },
  { href: "#work", label: "Work" },
  { href: "#about", label: "About" },
  { href: "#contact", label: "Contact" },
];

/** Decorative star positions for the mobile drawer background (kept low for performance). */
const drawerStars = Array.from({ length: 6 }, (_, i) => ({
  x: `${6 + ((i * 17.3) % 88)}%`,
  y: `${5 + ((i * 13.7) % 90)}%`,
  size: i % 4 === 0 ? 2.5 : i % 2 === 0 ? 1.5 : 1,
  delay: `${((i * 0.37) % 2.8).toFixed(2)}s`,
  duration: `${(2.2 + (i % 5) * 0.6).toFixed(1)}s`,
}));
---

<header class="navbar" data-navbar>
  <div class="navbar__track">
    <div class="navbar__aurora" aria-hidden="true"></div>

    <nav class="navbar__inner" aria-label="Main navigation">
      <a href="#home" class="navbar__brand">
        <span class="navbar__brand-orbit" aria-hidden="true">
          <span class="navbar__brand-core"></span>
          <span class="navbar__brand-ring"></span>
        </span>
        <span class="navbar__brand-text">Portfolio</span>
      </a>

      <ul class="navbar__links" role="list">
        {
          links.map((link) => (
            <li>
              <a href={link.href} class="navbar__link" data-nav-link>
                <span class="navbar__link-glow" aria-hidden="true"></span>
                <span class="navbar__link-trail" aria-hidden="true"></span>
                <span class="navbar__link-text">{link.label}</span>
              </a>
            </li>
          ))
        }
        <li class="navbar__indicator" aria-hidden="true" data-nav-indicator></li>
      </ul>

      <a href="#contact" class="navbar__cta">Let's talk</a>

      <button
        type="button"
        class="navbar__toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        data-nav-toggle
      >
        <span class="navbar__toggle-lines" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
      </button>
    </nav>
  </div>

  <div class="navbar__drawer" data-nav-drawer hidden>
    <div class="navbar__drawer-panel">
      <div class="navbar__drawer-cosmos" aria-hidden="true">
        <span class="navbar__drawer-aurora"></span>
        <span class="navbar__drawer-orbit"></span>
        {
          drawerStars.map((star) => (
            <span
              class="navbar__drawer-star"
              style={`left:${star.x};top:${star.y};--size:${star.size}px;--delay:${star.delay};--duration:${star.duration}`}
            />
          ))
        }
      </div>

      <button
        type="button"
        class="navbar__drawer-close"
        aria-label="Close menu"
      >
        <span class="navbar__drawer-close-icon" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
      </button>

      <header class="navbar__drawer-header">
        <p class="navbar__drawer-eyebrow">Navigate</p>
        <p class="navbar__drawer-title">Explore the cosmos</p>
        <div class="navbar__drawer-constellation" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
      </header>

      <ul class="navbar__drawer-links" role="list">
        {
          links.map((link, i) => (
            <li style={`--i: ${i}`}>
              <a href={link.href} class="navbar__drawer-link" data-nav-link>
                <span class="navbar__active-bar" aria-hidden="true"></span>
                <span class="navbar__link-trail navbar__link-trail--drawer" aria-hidden="true"></span>
                <span class="navbar__drawer-link-inner">
                  <span class="navbar__drawer-index">0{i + 1}</span>
                  <span class="navbar__drawer-label">{link.label}</span>
                </span>
                <span class="navbar__drawer-arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path
                      d="M5 12h14M13 6l6 6-6 6"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </span>
              </a>
              {i < links.length - 1 && (
                <div class="navbar__drawer-divider" aria-hidden="true"></div>
              )}
            </li>
          ))
        }
      </ul>

      <footer class="navbar__drawer-footer">
        <a href="#contact" class="navbar__drawer-cta">
          <span class="navbar__drawer-cta-shine" aria-hidden="true"></span>
          <span>Let's talk</span>
        </a>
        <p class="navbar__drawer-tagline">Open to new galaxies</p>
      </footer>
    </div>
  </div>
</header>

<script>
  /** Breakpoint matching the mobile drawer styles in CSS. */
  const MOBILE_BREAKPOINT = 768;

  /** Drawer close animation duration — fallback if transitionend never fires. */
  const DRAWER_CLOSE_MS = 500;

  // ── DOM references ──────────────────────────────────────────────────────────

  const navbar = document.querySelector<HTMLElement>("[data-navbar]");
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const drawer = document.querySelector<HTMLElement>("[data-nav-drawer]");
  const drawerPanel = drawer?.querySelector<HTMLElement>(".navbar__drawer-panel");
  const indicator = document.querySelector<HTMLElement>("[data-nav-indicator]");
  const navLinks = document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]");
  const desktopLinks = navbar?.querySelectorAll<HTMLAnchorElement>(
    ".navbar__links .navbar__link",
  );

  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /** Scroll position preserved while the drawer locks body scroll (iOS-safe). */
  let lockedScrollY = 0;

  // Unique section IDs derived from nav hrefs (e.g. "#work" → "work").
  const sectionIds = [
    ...new Set(
      Array.from(navLinks)
        .map((link) => link.getAttribute("href")?.slice(1) ?? "")
        .filter(Boolean),
    ),
  ];

  // ── Active link state ───────────────────────────────────────────────────────

  /** Syncs active classes on all nav links and moves the desktop pill indicator. */
  const setActiveNav = (hash: string) => {
    const activeHash = hash || "#home";

    navLinks.forEach((link) => {
      const isActive = link.getAttribute("href") === activeHash;
      link.classList.toggle("is-active", isActive);
      link.toggleAttribute("aria-current", isActive);
    });

    moveIndicator(activeHash);
  };

  /** Positions the sliding pill behind the active desktop link. Skipped on mobile. */
  const moveIndicator = (hash: string) => {
    if (!indicator || !desktopLinks?.length) return;
    if (window.innerWidth <= MOBILE_BREAKPOINT) return;

    const active = Array.from(desktopLinks).find(
      (link) => link.getAttribute("href") === hash,
    );
    if (!active) return;

    const list = indicator.parentElement;
    if (!list) return;

    const listRect = list.getBoundingClientRect();
    const linkRect = active.getBoundingClientRect();

    indicator.style.width = `${linkRect.width}px`;
    indicator.style.transform = `translateX(${linkRect.left - listRect.left}px)`;
    indicator.style.opacity = "1";
  };

  /**
   * Determines which section is active based on scroll position.
   * Uses a viewport marker at 32% from the top so sections activate
   * before they reach the middle of the screen.
   */
  const getActiveSection = () => {
    const marker = window.scrollY + window.innerHeight * 0.32;
    let active = "#home";

    for (const id of sectionIds) {
      const section = document.getElementById(id);
      if (section && section.offsetTop <= marker) {
        active = `#${id}`;
      }
    }

    return active;
  };

  /** Prefers the URL hash when valid; otherwise falls back to scroll position. */
  const updateActiveNav = () => {
    const hash = window.location.hash;
    const sectionId = hash ? hash.slice(1) : "";
    setActiveNav(sectionId && document.getElementById(sectionId) ? hash : getActiveSection());
  };

  // ── Mobile drawer ───────────────────────────────────────────────────────────

  const lockBodyScroll = () => {
    lockedScrollY = window.scrollY;
    document.body.style.position = "fixed";
    document.body.style.top = `-${lockedScrollY}px`;
    document.body.style.left = "0";
    document.body.style.right = "0";
    document.body.style.width = "100%";
    document.body.style.overflow = "hidden";
  };

  const unlockBodyScroll = () => {
    document.body.style.position = "";
    document.body.style.top = "";
    document.body.style.left = "";
    document.body.style.right = "";
    document.body.style.width = "";
    document.body.style.overflow = "";
    window.scrollTo(0, lockedScrollY);
  };

  /** Opens or closes the full-screen mobile menu. */
  const setDrawerOpen = (open: boolean) => {
    if (!toggle || !drawer || !navbar) return;

    toggle.setAttribute("aria-expanded", String(open));
    navbar.classList.toggle("navbar--open", open);

    if (open) {
      document.body.classList.add("menu-open");
      lockBodyScroll();
      drawer.classList.remove("navbar__drawer--closing");
      drawer.removeAttribute("hidden");
      // Force layout so mobile Safari paints the closed state before transitioning.
      void drawer.offsetHeight;
      requestAnimationFrame(() => {
        drawer.classList.add("is-visible");
      });
      return;
    }

    drawer.classList.add("navbar__drawer--closing");
    drawer.classList.remove("is-visible");
    document.body.classList.remove("menu-open");
    unlockBodyScroll();

    const hideDrawer = () => {
      if (!drawer.classList.contains("is-visible")) {
        drawer.setAttribute("hidden", "");
        drawer.classList.remove("navbar__drawer--closing");
      }
    };

    if (prefersReducedMotion) {
      hideDrawer();
      return;
    }

    // Wait for the panel fade on close (opacity finishes with the visible slide-out).
    const onPanelTransitionEnd = (event: TransitionEvent) => {
      if (event.target !== drawerPanel || event.propertyName !== "opacity") return;
      hideDrawer();
    };

    drawerPanel?.addEventListener("transitionend", onPanelTransitionEnd, { once: true });
    setTimeout(hideDrawer, DRAWER_CLOSE_MS);
  };

  if (toggle && drawer) {
    toggle.addEventListener("click", () => {
      setDrawerOpen(toggle.getAttribute("aria-expanded") !== "true");
    });

    drawer
      .querySelectorAll(".navbar__drawer-close, .navbar__drawer-link, .navbar__drawer-cta")
      .forEach((el) => {
        el.addEventListener("click", () => setDrawerOpen(false));
      });
  }

  // ── Scroll & resize listeners ───────────────────────────────────────────────

  if (navLinks.length) {
    const onScroll = () => {
      navbar?.classList.toggle("navbar--scrolled", window.scrollY > 20);
      updateActiveNav();
    };

    const onResize = () => {
      updateActiveNav();

      // Close drawer when crossing into desktop — avoids a stranded open menu.
      if (window.innerWidth > MOBILE_BREAKPOINT && navbar?.classList.contains("navbar--open")) {
        setDrawerOpen(false);
      }
    };

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("hashchange", updateActiveNav);
    window.addEventListener("resize", onResize);
  }
</script>

<style>
  /* ── Design tokens ───────────────────────────────────────────────────────── */

  .navbar {
    --nav-accent: #c8b0ff;
    --nav-accent-bright: #ebe4ff;
    --nav-text: rgba(248, 250, 255, 0.95);
    --nav-muted: rgba(220, 228, 255, 0.55);
    --nav-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --nav-max: 72rem;

    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    padding: 1.25rem clamp(1rem, 4vw, 2rem);
    pointer-events: none;
    transition: padding 0.45s var(--nav-ease);
  }

  .navbar--scrolled {
    padding-block: 0.7rem;
  }

  /* ── Desktop bar shell ───────────────────────────────────────────────────── */

  .navbar__track {
    position: relative;
    max-width: var(--nav-max);
    margin-inline: auto;
    border-radius: 999px;
    pointer-events: auto;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(200, 176, 255, 0.45) 0%,
      rgba(255, 255, 255, 0.08) 35%,
      rgba(140, 100, 220, 0.35) 65%,
      rgba(200, 176, 255, 0.25) 100%
    );
    background-size: 200% 200%;
    animation: aurora-shift 8s ease infinite;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.28),
      0 0 0 1px rgba(255, 255, 255, 0.04);
    transition: box-shadow 0.45s var(--nav-ease);
  }

  .navbar--scrolled .navbar__track {
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.35),
      0 0 40px rgba(140, 90, 220, 0.08);
  }

  @keyframes aurora-shift {
    0%,
    100% {
      background-position: 0% 50%;
    }

    50% {
      background-position: 100% 50%;
    }
  }

  .navbar__aurora {
    position: absolute;
    inset: -20px;
    border-radius: inherit;
    background: radial-gradient(
      ellipse 60% 80% at 50% 0%,
      rgba(180, 140, 255, 0.12) 0%,
      transparent 70%
    );
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.45s ease;
  }

  .navbar--scrolled .navbar__aurora {
    opacity: 1;
  }

  .navbar__inner {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.5rem 0.5rem 0.5rem 1.25rem;
    border-radius: inherit;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.09) 0%,
        transparent 42%
      ),
      linear-gradient(
        135deg,
        rgba(22, 24, 44, 0.96) 0%,
        rgba(10, 12, 26, 0.98) 100%
      );
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1);
    overflow: hidden;
  }

  .navbar__inner::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.04;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* Brand */
  .navbar__brand {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--nav-text);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    flex-shrink: 0;
    transition: color 0.2s ease;
  }

  .navbar__brand:hover {
    color: var(--nav-accent-bright);
  }

  .navbar__brand-orbit {
    position: relative;
    width: 1.75rem;
    height: 1.75rem;
    flex-shrink: 0;
  }

  .navbar__brand-core {
    position: absolute;
    inset: 35%;
    border-radius: 50%;
    background: var(--nav-accent);
    box-shadow: 0 0 12px rgba(200, 176, 255, 0.6);
  }

  .navbar__brand-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(200, 176, 255, 0.35);
    animation: orbit-spin 6s linear infinite;
  }

  .navbar__brand-ring::after {
    content: "";
    position: absolute;
    top: -2px;
    left: 50%;
    width: 4px;
    height: 4px;
    margin-left: -2px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 6px rgba(200, 176, 255, 0.9);
  }

  @keyframes orbit-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .navbar__brand-text {
    background: linear-gradient(135deg, #fff 30%, var(--nav-accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ── Desktop nav links ───────────────────────────────────────────────────── */

  .navbar__links {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    list-style: none;
    margin: 0 auto;
    padding: 0;
  }

  .navbar__link {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 1.1rem;
    text-decoration: none;
    color: var(--nav-muted);
    font-size: 0.875rem;
    font-weight: 450;
    letter-spacing: 0.02em;
    border-radius: 999px;
    transition: color 0.25s ease;
  }

  .navbar__link:not(.is-active):is(:hover, :focus-visible) {
    z-index: 2;
  }

  .navbar__link:hover {
    color: var(--nav-text);
  }

  .navbar__link.is-active {
    color: var(--nav-text);
  }

  /* Hover glow — desktop only (touch devices rarely trigger :hover) */
  .navbar__link-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 145%;
    height: 210%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
    overflow: visible;
  }

  .navbar__link-glow::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: 58%;
    height: 75%;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(0.5);
    background: radial-gradient(
      ellipse 48% 42% at center,
      rgba(215, 175, 255, 0.95) 0%,
      rgba(190, 135, 255, 0.62) 19%,
      rgba(170, 110, 245, 0.3) 38%,
      rgba(150, 90, 230, 0.08) 52%,
      transparent 65%
    );
    opacity: 0;
    filter: blur(14px);
    transition:
      opacity 0.35s ease,
      transform 0.5s var(--nav-ease),
      filter 0.5s ease;
  }

  .navbar__link:not(.is-active):is(:hover, :focus-visible) .navbar__link-glow::before {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.35);
    filter: blur(24px);
  }

  .navbar__link:not(.is-active):is(:hover, :focus-visible) .navbar__link-text {
    text-shadow:
      0 0 11px rgba(200, 160, 255, 0.72),
      0 0 20px rgba(170, 120, 255, 0.4);
  }

  .navbar__link-text,
  .navbar__drawer-label {
    position: relative;
    z-index: 1;
  }

  /* Shared active label style for desktop and mobile */
  :is(.navbar__link, .navbar__drawer-link).is-active :is(.navbar__link-text, .navbar__drawer-label) {
    font-weight: 500;
    letter-spacing: 0.03em;
    background: linear-gradient(135deg, rgba(248, 250, 255, 0.98) 25%, #c4a8f5 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Comet trail — shared by desktop and mobile active links */
  .navbar__link-trail {
    position: absolute;
    z-index: 1;
    bottom: 0.22rem;
    left: 14%;
    right: 14%;
    height: 1.5px;
    border-radius: 2px;
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
    transition: opacity 0.4s var(--nav-ease);
  }

  .navbar__link-trail--drawer {
    z-index: 0;
    bottom: 0.35rem;
    left: 3.5rem;
    right: 3rem;
  }

  :is(.navbar__link, .navbar__drawer-link).is-active .navbar__link-trail {
    opacity: 1;
  }

  .navbar__link-trail::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(170, 130, 240, 0.28) 22%,
      rgba(195, 165, 255, 0.45) 50%,
      rgba(170, 130, 240, 0.28) 78%,
      transparent 100%
    );
  }

  .navbar__link-trail::after {
    content: "";
    position: absolute;
    top: -2px;
    left: -35%;
    width: 35%;
    height: 5px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(210, 185, 255, 0.55) 45%,
      rgba(230, 215, 255, 0.35) 55%,
      transparent 100%
    );
    filter: blur(2px);
    animation: comet-run 3.2s ease-in-out infinite;
  }

  @keyframes comet-run {
    0% {
      left: -35%;
      opacity: 0;
    }

    12% {
      opacity: 1;
    }

    88% {
      opacity: 1;
    }

    100% {
      left: 100%;
      opacity: 0;
    }
  }

  /* Sliding pill behind the active desktop link */
  .navbar__indicator {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(
      135deg,
      rgba(175, 135, 245, 0.14) 0%,
      rgba(200, 176, 255, 0.07) 45%,
      rgba(155, 105, 230, 0.11) 100%
    );
    border: 1px solid rgba(200, 176, 255, 0.16);
    box-shadow:
      0 0 18px rgba(150, 100, 220, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
    transition:
      transform 0.4s var(--nav-ease),
      width 0.4s var(--nav-ease),
      opacity 0.3s ease;
    will-change: transform, width;
  }

  .navbar__indicator::before {
    content: "";
    position: absolute;
    inset: -80%;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      rgba(195, 165, 255, 0.12) 70deg,
      transparent 140deg,
      rgba(175, 135, 245, 0.08) 220deg,
      transparent 300deg
    );
    animation: indicator-aurora 7s linear infinite;
  }

  .navbar__indicator::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      105deg,
      transparent 42%,
      rgba(255, 255, 255, 0.07) 50%,
      transparent 58%
    );
    animation: indicator-shimmer 5s ease-in-out infinite;
  }

  @keyframes indicator-aurora {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes indicator-shimmer {
    0%,
    70%,
    100% {
      transform: translateX(-120%);
      opacity: 0;
    }

    82% {
      opacity: 1;
    }

    90% {
      transform: translateX(120%);
    }
  }

  /* CTA */
  .navbar__cta {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: #0a0c18;
    background: linear-gradient(135deg, var(--nav-accent-bright) 0%, var(--nav-accent) 100%);
    box-shadow:
      0 2px 16px rgba(160, 110, 240, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.4);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .navbar__cta:hover {
    transform: translateY(-1px);
    box-shadow:
      0 4px 24px rgba(160, 110, 240, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  /* Hamburger */
  .navbar__toggle {
    display: none;
    position: relative;
    z-index: 1;
    width: 2.5rem;
    height: 2.5rem;
    margin-left: auto;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    cursor: pointer;
    transition:
