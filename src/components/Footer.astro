---
/**
 * Footer — contact CTA, navigation, social links, and lightweight backdrop.
 * Scroll reveals: opacity-only fades via IntersectionObserver (see .footer-reveal).
 * Global StarField + NebulaSky provide the cosmic atmosphere.
 */

interface Props {
	facebookUrl?: string;
	instagramUrl?: string;
	email?: string;
	phone?: string;
}

const {
	facebookUrl = 'https://facebook.com',
	instagramUrl = 'https://instagram.com',
	email = 'hello@portfolio.dev',
	phone = '+963956667367',
} = Astro.props;

/** Strip spaces for tel: href; format +XXX XXX XXX XXXX for display */
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;
const phoneDisplay = phone.replace(/^(\+\d{3})(\d{3})(\d{3})(\d{3})$/, '$1 $2 $3 $4');

const navLinks = [
	{ href: '#home', label: 'Home' },
	{ href: '#work', label: 'Work' },
	{ href: '#about', label: 'About' },
	{ href: '#contact', label: 'Contact' },
] as const;

type SocialId = 'facebook' | 'instagram';
type ContactId = 'email' | 'phone';

interface SocialChannel {
	id: SocialId;
	href: string;
	label: string;
	ariaLabel: string;
}

interface ContactChannel {
	id: ContactId;
	href: string;
	label: string;
	value: string;
}

const socialChannels: SocialChannel[] = [
	{
		id: 'facebook',
		href: facebookUrl,
		label: 'Facebook',
		ariaLabel: 'Follow on Facebook',
	},
	{
		id: 'instagram',
		href: instagramUrl,
		label: 'Instagram',
		ariaLabel: 'Follow on Instagram',
	},
];

const contactChannels: ContactChannel[] = [
	{ id: 'email', href: `mailto:${email}`, label: 'Email', value: email },
	{ id: 'phone', href: phoneHref, label: 'Phone', value: phoneDisplay },
];

/** Stagger delays for opacity-only scroll reveals */
const revealDelay = {
	cta: '0.05s',
	divider: '0.1s',
	brand: '0.14s',
	nav: '0.18s',
	social: '0.24s',
	contact: '0.3s',
	bar: '0.36s',
} as const;

const year = new Date().getFullYear();
---

<footer class="footer" id="contact" data-footer>
	<!-- Lightweight backdrop — StarField + NebulaSky carry the cosmic look -->
	<div class="footer__aurora" aria-hidden="true">
		<span class="footer__aurora-band footer__aurora-band--1"></span>
		<span class="footer__aurora-band footer__aurora-band--2"></span>
		<span class="footer__aurora-band footer__aurora-band--3"></span>
	</div>

	<div class="footer__beam" aria-hidden="true">
		<span class="footer__beam-line"></span>
		<span class="footer__beam-glow"></span>
	</div>

	<div class="container footer__inner">
		<!-- CTA panel -->
		<div
			class="footer__cta-panel glass-panel footer-reveal"
			style={`--reveal-delay: ${revealDelay.cta}`}
		>
			<div class="footer__cta-glow" aria-hidden="true"></div>
			<div class="footer__cta-content">
				<p class="eyebrow footer__cta-eyebrow">Ready for liftoff?</p>
				<h2 class="footer__cta-title">
					Let's build something <span class="gradient-text">cosmic</span>
				</h2>
				<p class="body-regular footer__cta-desc">
					Open to collaborations, freelance missions, and bold ideas across the digital universe.
				</p>
			</div>
			<a href={`mailto:${email}`} class="cta-btn">
				<span>Start a conversation</span>
				<svg class="cta-btn__arrow" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path
						d="M5 12h14M13 6l6 6-6 6"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
						stroke-linejoin="round"
					/>
				</svg>
			</a>
		</div>

		<hr class="divider footer__divider footer-reveal" style={`--reveal-delay: ${revealDelay.divider}`} />

		<div class="footer__grid">
			<!-- Brand column -->
			<div class="footer__brand footer-reveal" style={`--reveal-delay: ${revealDelay.brand}`}>
				<a href="#home" class="footer__brand-link">
					<span class="footer__brand-text">Portfolio</span>
				</a>
				<p class="footer__brand-tagline">
					Full-stack developer & creative technologist crafting immersive digital experiences.
				</p>
				<p class="badge">
					<span class="badge__dot" aria-hidden="true"></span>
					Available for new projects
				</p>
			</div>

			<!-- Navigation — reuses navbar link styles; active state synced via data-nav-link -->
			<nav class="footer__nav footer-reveal" style={`--reveal-delay: ${revealDelay.nav}`} aria-label="Footer navigation">
				<p class="caption footer__col-label">Navigate</p>
				<ul class="navbar__links footer__nav-links" role="list">
					{
						navLinks.map((link) => (
							<li>
								<a href={link.href} class="navbar__link" data-nav-link>
									<span class="navbar__link-pill" aria-hidden="true"></span>
									<span class="navbar__link-glow" aria-hidden="true"></span>
									<span class="navbar__link-trail" aria-hidden="true"></span>
									<span class="navbar__link-text">{link.label}</span>
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<!-- Social channels -->
			<div class="footer__social footer-reveal" style={`--reveal-delay: ${revealDelay.social}`}>
				<p class="caption footer__col-label">Connect</p>
				<ul class="footer__channel-list" role="list">
					{
						socialChannels.map((channel) => (
							<li>
								<a
									href={channel.href}
									class={`footer__channel-link footer__social-link footer__social-link--${channel.id}`}
									target="_blank"
									rel="noopener noreferrer"
									aria-label={channel.ariaLabel}
								>
									<span class="footer__channel-border" aria-hidden="true"></span>
									<span class="footer__channel-shine" aria-hidden="true"></span>
									<span class="footer__channel-icon" aria-hidden="true">
										{channel.id === 'facebook' && (
											<svg viewBox="0 0 24 24" fill="currentColor">
												<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
											</svg>
										)}
										{channel.id === 'instagram' && (
											<svg viewBox="0 0 24 24" fill="currentColor">
												<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
											</svg>
										)}
									</span>
									<span class="footer__channel-text">
										<span class="footer__channel-label">{channel.label}</span>
										<span class="footer__channel-value">Follow us</span>
									</span>
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<!-- Contact channels -->
			<div class="footer__contact footer-reveal" style={`--reveal-delay: ${revealDelay.contact}`}>
				<p class="caption footer__col-label">Signal</p>
				<ul class="footer__channel-list" role="list">
					{
						contactChannels.map((channel) => (
							<li>
								<a
									href={channel.href}
									class={`footer__channel-link footer__channel-link--${channel.id}`}
								>
									<span class="footer__channel-border" aria-hidden="true"></span>
									<span class="footer__channel-shine" aria-hidden="true"></span>
									<span class="footer__channel-icon" aria-hidden="true">
										{channel.id === 'email' && (
											<svg viewBox="0 0 24 24" fill="none">
												<rect x="2" y="4" width="20" height="16" rx="3" stroke="currentColor" stroke-width="1.5" />
												<path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
											</svg>
										)}
										{channel.id === 'phone' && (
											<svg viewBox="0 0 24 24" fill="none">
												<path
													d="M8.5 3.5h7A2.5 2.5 0 0118 6v12a2.5 2.5 0 01-2.5 2.5h-7A2.5 2.5 0 016 18V6a2.5 2.5 0 012.5-2.5z"
													stroke="currentColor"
													stroke-width="1.5"
												/>
												<path d="M11 17.5h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
											</svg>
										)}
									</span>
									<span class="footer__channel-text">
										<span class="footer__channel-label">{channel.label}</span>
										<span class="footer__channel-value">{channel.value}</span>
									</span>
								</a>
							</li>
						))
					}
				</ul>
				<p class="legal-text footer__timezone">Earth · UTC+0</p>
			</div>
		</div>

		<div class="footer__bar footer-reveal" style={`--reveal-delay: ${revealDelay.bar}`}>
			<p class="legal-text footer__copyright">
				© {year} Portfolio. Crafted among the stars.
			</p>
		</div>
	</div>
</footer>

<script>
	const initFooterReveals = () => {
		document.documentElement.classList.add('js-footer-reveals');

		const footer = document.querySelector('[data-footer]');
		if (!footer) return;

		const items = footer.querySelectorAll<HTMLElement>('.footer-reveal');
		if (!items.length) return;

		const reveal = (el: HTMLElement) => el.classList.add('is-visible');

		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
			items.forEach(reveal);
			return;
		}

		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (!entry.isIntersecting) continue;
					reveal(entry.target as HTMLElement);
					observer.unobserve(entry.target);
				}
			},
			{ threshold: 0.06, rootMargin: '0px 0px -32px 0px' },
		);

		for (const el of items) {
			if (el.getBoundingClientRect().top < window.innerHeight * 0.92) {
				reveal(el);
			} else {
				observer.observe(el);
			}
		}
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initFooterReveals, { once: true });
	} else {
		initFooterReveals();
	}
</script>

<style is:global>
	@keyframes footer-reveal-kf {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	/* Hidden only when JS is active — visible by default (no-JS / observer fallback) */
	html.js-footer-reveals [data-footer] .footer-reveal:not(.is-visible) {
		opacity: 0;
		animation: footer-reveal-kf 0.55s var(--ease-out) both paused;
		animation-delay: var(--reveal-delay, 0s);
	}

	html.js-footer-reveals [data-footer] .footer-reveal.is-visible {
		animation-play-state: running;
	}
</style>

<style>
	/* ── Shell ── */
	.footer {
		--footer-ease: var(--ease-out);
		position: relative;
		z-index: 5;
		margin-top: var(--space-2xl);
		padding: var(--space-2xl) 0 var(--space-lg);
		overflow: hidden;
		isolation: isolate;
	}

	.footer__inner {
		position: relative;
		z-index: 1;
	}

	/* ── Aurora backdrop (static gradients, opacity-only pulse) ── */
	.footer__aurora {
		position: absolute;
		inset: 0 0 auto;
		height: 240px;
		pointer-events: none;
		overflow: hidden;
		contain: paint;
		mask-image: linear-gradient(180deg, black 0%, transparent 100%);
		-webkit-mask-image: linear-gradient(180deg, black 0%, transparent 100%);
	}

	.footer__aurora-band {
		position: absolute;
		width: 130%;
		height: 100px;
		left: -15%;
		border-radius: 50%;
		opacity: 0.35;
	}

	.footer__aurora-band--1 {
		top: -30px;
		background: radial-gradient(ellipse, rgba(140, 80, 220, 0.45) 0%, transparent 72%);
		animation: footer-aurora-fade 10s ease-in-out infinite;
	}

	.footer__aurora-band--2 {
		top: 24px;
		left: -5%;
		background: radial-gradient(ellipse, rgba(100, 64, 180, 0.32) 0%, transparent 68%);
		animation: footer-aurora-fade 14s ease-in-out infinite reverse;
	}

	.footer__aurora-band--3 {
		top: 52px;
		left: 28%;
		background: radial-gradient(ellipse, rgba(200, 176, 255, 0.2) 0%, transparent 62%);
		animation: footer-aurora-fade 18s ease-in-out infinite;
		animation-delay: -5s;
	}

	@keyframes footer-aurora-fade {
		0%,
		100% {
			opacity: 0.28;
		}
		50% {
			opacity: 0.48;
		}
	}

	/* ── Animated top beam (transform-only sweep) ── */
	.footer__beam {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		overflow: hidden;
		pointer-events: none;
	}

	.footer__beam-line {
		display: block;
		width: 100%;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent 0%,
			var(--color-glass-border) 20%,
			var(--color-accent) 50%,
			var(--color-glass-border) 80%,
			transparent 100%
		);
		opacity: 0.6;
	}

	.footer__beam-glow {
		position: absolute;
		top: -1px;
		left: 0;
		width: 120px;
		height: 3px;
		background: linear-gradient(
			90deg,
			transparent,
			var(--color-accent-bright),
			var(--color-accent),
			transparent
		);
		opacity: 0;
		transform: translateX(-12vw);
		animation: footer-beam-sweep 5s var(--footer-ease) infinite;
	}

	@keyframes footer-beam-sweep {
		0% {
			transform: translateX(-12vw);
			opacity: 0;
		}
		10% {
			opacity: 1;
		}
		90% {
			opacity: 1;
		}
		100% {
			transform: translateX(112vw);
			opacity: 0;
		}
	}

	/* Visible by default — JS gates the hidden state in the global block above */
	.footer-reveal {
		opacity: 1;
	}

	/* ── CTA panel ── */
	.footer__cta-panel {
		position: relative;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md) var(--space-lg);
		padding: clamp(1.75rem, 4vw, 2.5rem) clamp(1.5rem, 4vw, 2.75rem);
		border-radius: 1.5rem;
		border: 1px solid var(--color-glass-border);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.1),
			0 24px 64px rgba(0, 0, 0, 0.35);
		overflow: hidden;
	}

	.footer__cta-glow {
		position: absolute;
		top: -50%;
		left: -20%;
		width: 60%;
		height: 200%;
		background: radial-gradient(ellipse, rgba(200, 176, 255, 0.12) 0%, transparent 65%);
		pointer-events: none;
		animation: footer-cta-glow 8s ease-in-out infinite;
	}

	@keyframes footer-cta-glow {
		0%,
		100% {
			opacity: 0.45;
		}
		50% {
			opacity: 0.85;
		}
	}

	.footer__cta-content {
		position: relative;
		flex: 1 1 280px;
		max-width: 36rem;
	}

	.footer__cta-eyebrow {
		margin-bottom: var(--space-xs);
	}

	.footer__cta-title {
		font-size: clamp(1.5rem, 3.5vw, 2.25rem);
		font-weight: 300;
		line-height: 1.2;
		margin-bottom: var(--space-sm);
	}

	.footer__cta-desc {
		max-width: 32rem;
	}

	.footer__divider {
		margin: var(--space-xl) 0;
	}

	/* ── Content grid ── */
	.footer__grid {
		display: grid;
		grid-template-columns: 1.4fr repeat(3, 1fr);
		gap: var(--space-lg) var(--space-md);
	}

	.footer__col-label {
		margin-bottom: var(--space-sm);
		color: var(--color-text-subtle);
	}

	/* ── Brand ── */
	.footer__brand-link {
		display: inline-block;
		margin-bottom: var(--space-sm);
		text-decoration: none;
		color: var(--color-text-primary);
		font-size: 1rem;
		font-weight: 500;
		letter-spacing: 0.03em;
		transition: color 0.2s ease;
	}

	.footer__brand-link:hover {
		color: var(--color-accent-bright);
	}

	.footer__brand-text {
		background: linear-gradient(135deg, #fff 30%, var(--color-accent) 100%);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.footer__brand-tagline {
		font-size: 0.9rem;
		line-height: 1.65;
		color: var(--color-text-muted);
		max-width: 22rem;
		margin-bottom: var(--space-sm);
	}

	/* ── Footer nav (navbar link styles; glow/trail hidden in global.css) ── */
	.footer__nav-links {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.15rem;
		margin: 0;
		padding: 0;
	}

	/* ── Channel cards (social + contact) ── */
	.footer__channel-list {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.footer__channel-link {
		position: relative;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		width: 100%;
		min-height: 4.35rem;
		padding: 0.75rem 1rem;
		border-radius: 0.85rem;
		color: var(--color-text-muted);
		text-decoration: none;
		background: var(--glass-card-fill);
		border: 1px solid var(--color-glass-border);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
		overflow: hidden;
		transition:
			color 0.3s ease,
			border-color 0.3s ease,
			transform 0.35s var(--footer-ease),
			box-shadow 0.35s ease;
	}

	.footer__channel-link svg {
		flex-shrink: 0;
		transition: transform 0.35s var(--footer-ease);
	}

	.footer__channel-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		flex-shrink: 0;
		border-radius: 0.55rem;
		color: var(--color-accent);
		background: rgba(200, 176, 255, 0.08);
		border: 1px solid rgba(200, 176, 255, 0.14);
	}

	.footer__channel-icon svg {
		width: 1rem;
		height: 1rem;
	}

	.footer__channel-text {
		display: flex;
		flex: 1;
		flex-direction: column;
		justify-content: center;
		gap: 0.12rem;
		min-width: 0;
		min-height: 2.35rem;
	}

	.footer__channel-label {
		font-size: 0.68rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-text-subtle);
		line-height: 1.2;
	}

	.footer__channel-value {
		font-size: 0.88rem;
		font-weight: 500;
		letter-spacing: 0.02em;
		color: var(--color-text-primary);
		line-height: 1.35;
		word-break: break-word;
	}

	/* Animated conic border + shine sweep on hover */
	.footer__channel-border {
		position: absolute;
		inset: 0;
		border-radius: inherit;
		padding: 1px;
		background: conic-gradient(
			from var(--footer-border-angle, 0deg),
			transparent 0%,
			var(--color-accent) 25%,
			transparent 50%,
			var(--color-accent-soft) 75%,
			transparent 100%
		);
		-webkit-mask:
			linear-gradient(#fff 0 0) content-box,
			linear-gradient(#fff 0 0);
		mask:
			linear-gradient(#fff 0 0) content-box,
			linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	@property --footer-border-angle {
		syntax: '<angle>';
		initial-value: 0deg;
		inherits: false;
	}

	.footer__channel-shine {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			105deg,
			transparent 40%,
			rgba(255, 255, 255, 0.08) 50%,
			transparent 60%
		);
		transform: translateX(-120%);
		transition: transform 0.6s var(--footer-ease);
	}

	.footer__channel-link:hover,
	.footer__channel-link:focus-visible {
		color: var(--color-text-primary);
		border-color: transparent;
		transform: translateY(-3px);
