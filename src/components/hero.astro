---
interface Props {
	badge?: string;
	headline?: string[];
	subheadline?: string;
	roles?: string[];
}

const {
	badge = 'Open to new galaxies',
	headline = ['Crafting', 'digital', 'constellations'],
	subheadline = 'Full-stack developer & creative technologist building immersive experiences where code meets the cosmos.',
	roles = ['Developer', 'Designer', 'Explorer'],
} = Astro.props;

const stats = [
	{ value: '5+', label: 'Years' },
	{ value: '20+', label: 'Projects' },
	{ value: '∞', label: 'Curiosity' },
];
---

<section class="hero" data-hero>
	<div class="hero-singularity" aria-hidden="true" data-hero-parallax>
		<div class="singularity-core"></div>
		<div class="singularity-glow"></div>
		<div class="orbit orbit--1"><span class="orbit-dot"></span></div>
		<div class="orbit orbit--2"><span class="orbit-dot"></span></div>
		<div class="orbit orbit--3"><span class="orbit-dot"></span></div>
		<div class="singularity-rays">
			{[0, 30, 60, 90, 120, 150].map((angle) => (
				<span class="ray" style={`--ray-angle: ${angle}deg`}></span>
			))}
		</div>
	</div>

	<div class="hero-grid">
		<div class="hero-content">
			<p class="hero-badge" data-reveal>
				<span class="hero-badge-pulse" aria-hidden="true"></span>
				{badge}
			</p>

			<h1 class="hero-headline">
				{headline.map((line, i) => (
					<span class="hero-headline-line" data-reveal style={`--delay: ${0.1 + i * 0.12}s`}>
						<span class="hero-headline-text">{line}</span>
					</span>
				))}
			</h1>

			<div class="hero-roles" data-reveal style="--delay: 0.46s" aria-label="Roles">
				{roles.map((role, i) => (
					<span class="hero-role" style={`--role-index: ${i}`}>{role}</span>
				))}
			</div>

			<p class="hero-sub" data-reveal style="--delay: 0.58s">
				{subheadline}
			</p>

			<div class="hero-actions" data-reveal style="--delay: 0.7s">
				<a href="#work" class="hero-cta hero-cta--primary">
					<span class="hero-cta-border" aria-hidden="true"></span>
					<span class="hero-cta-inner">View work</span>
				</a>
				<a href="#contact" class="hero-cta hero-cta--ghost">
					<span class="hero-cta-inner">Let's talk</span>
				</a>
			</div>

			<div class="hero-stats" data-reveal style="--delay: 0.82s">
				{stats.map((stat, i) => (
					<>
						{i > 0 && <span class="hero-stat-divider" aria-hidden="true"></span>}
						<div class="hero-stat">
							<span class="hero-stat-value">{stat.value}</span>
							<span class="hero-stat-label">{stat.label}</span>
						</div>
					</>
				))}
			</div>
		</div>
	</div>

	<a href="#work" class="hero-scroll" aria-label="Scroll to work" data-reveal style="--delay: 1s">
		<span class="hero-scroll-line" aria-hidden="true"></span>
		<span class="hero-scroll-text">Explore</span>
	</a>
</section>

<script>
	const hero = document.querySelector<HTMLElement>('[data-hero]');
	const parallax = document.querySelector<HTMLElement>('[data-hero-parallax]');
	const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (hero && !reducedMotion) {
		hero.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
			el.classList.add('is-visible');
		});
	}

	if (parallax && hero && !reducedMotion) {
		let targetX = 0;
		let targetY = 0;
		let currentX = 0;
		let currentY = 0;
		let rafId = 0;

		const onMove = (e: PointerEvent) => {
			const rect = hero.getBoundingClientRect();
			const x = (e.clientX - rect.left) / rect.width - 0.5;
			const y = (e.clientY - rect.top) / rect.height - 0.5;
			targetX = x * 28;
			targetY = y * 22;
		};

		const tick = () => {
			currentX += (targetX - currentX) * 0.08;
			currentY += (targetY - currentY) * 0.08;
			parallax.style.setProperty('--parallax-x', `${currentX}px`);
			parallax.style.setProperty('--parallax-y', `${currentY}px`);
			rafId = requestAnimationFrame(tick);
		};

		hero.addEventListener('pointermove', onMove);
		hero.addEventListener('pointerleave', () => {
			targetX = 0;
			targetY = 0;
		});
		rafId = requestAnimationFrame(tick);

		document.addEventListener('astro:before-swap', () => {
			cancelAnimationFrame(rafId);
		}, { once: true });
	}

	if (hero && reducedMotion) {
		hero.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
			el.classList.add('is-visible');
		});
	}
</script>

<style>
	.hero {
		--hero-accent: #c8b0ff;
		--hero-accent-bright: #ebe4ff;
		--hero-accent-dim: rgba(200, 176, 255, 0.35);
		--hero-text: rgba(248, 250, 255, 0.96);
		--hero-muted: rgba(220, 228, 255, 0.62);
		--hero-ease: cubic-bezier(0.22, 1, 0.36, 1);
		--hero-glass: rgba(255, 255, 255, 0.06);
		--hero-glass-border: rgba(255, 255, 255, 0.1);

		position: relative;
		width: 100%;
		height: 100vh;
		height: 100svh;
		min-height: 100vh;
		min-height: 100svh;
		max-height: 100vh;
		max-height: 100svh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding:
			clamp(5rem, 12svh, 7rem)
			clamp(1.25rem, 5vw, 3rem)
			clamp(3rem, 8svh, 4.5rem);
		overflow: hidden;
		isolation: isolate;
	}

	.hero-grid {
		position: relative;
		z-index: 2;
		width: 100%;
		max-width: 72rem;
		margin-inline: auto;
	}

	.hero-content {
		max-width: 42rem;
	}

	/* ── Singularity visual ── */
	.hero-singularity {
		--parallax-x: 0px;
		--parallax-y: 0px;

		position: absolute;
		top: 42%;
		right: clamp(-4rem, 8vw, 6rem);
		width: clamp(18rem, 42vw, 32rem);
		height: clamp(18rem, 42vw, 32rem);
		transform: translateY(-50%) translate(var(--parallax-x), var(--parallax-y));
		pointer-events: none;
		z-index: 0;
		will-change: transform;
	}

	.singularity-core {
		position: absolute;
		inset: 38%;
		border-radius: 50%;
		background: radial-gradient(
			circle at 40% 35%,
			#fff 0%,
			var(--hero-accent-bright) 18%,
			var(--hero-accent) 45%,
			rgba(120, 60, 200, 0.6) 70%,
			transparent 100%
		);
		box-shadow:
			0 0 40px rgba(200, 176, 255, 0.7),
			0 0 80px rgba(140, 80, 220, 0.4),
			0 0 140px rgba(100, 50, 180, 0.25);
		animation: core-pulse 4s ease-in-out infinite;
	}

	.singularity-glow {
		position: absolute;
		inset: 10%;
		border-radius: 50%;
		background: radial-gradient(
			circle,
			rgba(200, 176, 255, 0.18) 0%,
			rgba(140, 80, 220, 0.08) 40%,
			transparent 70%
		);
		filter: blur(20px);
		animation: glow-breathe 6s ease-in-out infinite;
	}

	.orbit {
		position: absolute;
		inset: 0;
		border-radius: 50%;
		border: 1px solid transparent;
		transform-style: preserve-3d;
	}

	.orbit--1 {
		border-color: rgba(200, 176, 255, 0.22);
		transform: rotateX(72deg);
		animation: orbit-spin 18s linear infinite;
	}

	.orbit--2 {
		inset: 8%;
		border-color: rgba(180, 150, 255, 0.16);
		transform: rotateX(68deg) rotateZ(60deg);
		animation: orbit-spin 24s linear infinite reverse;
	}

	.orbit--3 {
		inset: 16%;
		border-color: rgba(220, 200, 255, 0.12);
		transform: rotateX(75deg) rotateZ(-30deg);
		animation: orbit-spin 14s linear infinite;
	}

	.orbit-dot {
		position: absolute;
		top: -3px;
		left: 50%;
		width: 6px;
		height: 6px;
		margin-left: -3px;
		border-radius: 50%;
		background: var(--hero-accent-bright);
		box-shadow: 0 0 12px var(--hero-accent);
	}

	.orbit--2 .orbit-dot {
		width: 4px;
		height: 4px;
		margin-left: -2px;
		top: -2px;
		opacity: 0.7;
	}

	.singularity-rays {
		position: absolute;
		inset: 20%;
	}

	.ray {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 1px;
		height: 45%;
		margin-left: -0.5px;
		transform-origin: center top;
		transform: rotate(var(--ray-angle)) translateY(-50%);
		background: linear-gradient(
			180deg,
			rgba(235, 228, 255, 0.35) 0%,
			rgba(200, 176, 255, 0.08) 60%,
			transparent 100%
		);
		opacity: 0.5;
		animation: ray-flicker 3s ease-in-out infinite;
		animation-delay: calc(var(--ray-angle) / 360deg * 2s);
	}

	/* ── Badge ── */
	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		margin-bottom: 1.75rem;
		padding: 0.4rem 0.9rem 0.4rem 0.65rem;
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--hero-accent);
		background: var(--hero-glass);
		border: 1px solid var(--hero-glass-border);
		border-radius: 999px;
		backdrop-filter: blur(12px) saturate(140%);
		-webkit-backdrop-filter: blur(12px) saturate(140%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.12),
			0 8px 32px rgba(0, 0, 0, 0.2);
	}

	.hero-badge-pulse {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: #7dffa8;
		box-shadow: 0 0 10px rgba(125, 255, 168, 0.8);
		animation: badge-pulse 2.4s ease-in-out infinite;
	}

	/* ── Headline ── */
	.hero-headline {
		display: flex;
		flex-direction: column;
		gap: 0.05em;
		margin-bottom: 1.25rem;
		font-size: clamp(2.6rem, 7.5vw, 5rem);
		font-weight: 300;
		line-height: 1.02;
		letter-spacing: -0.03em;
	}

	.hero-headline-line {
		display: block;
		overflow: hidden;
	}

	.hero-headline-text {
		display: inline-block;
		background: linear-gradient(
			120deg,
			var(--hero-text) 0%,
			var(--hero-accent-bright) 35%,
			var(--hero-accent) 55%,
			var(--hero-text) 80%
		);
		background-size: 200% auto;
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		animation: shimmer 6s ease-in-out infinite;
	}

	.hero-headline-line:nth-child(2) .hero-headline-text {
		animation-delay: -2s;
	}

	.hero-headline-line:nth-child(3) .hero-headline-text {
		animation-delay: -4s;
		font-weight: 400;
	}

	/* ── Role ticker ── */
	.hero-roles {
		position: relative;
		height: 1.6rem;
		margin-bottom: 1.5rem;
		overflow: hidden;
	}

	.hero-role {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		font-size: 0.85rem;
		font-weight: 500;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--hero-muted);
		opacity: 0;
		transform: translateY(100%);
		animation: role-cycle 9s ease-in-out infinite;
		animation-delay: calc(var(--role-index) * 3s);
	}

	.hero-role::after {
		content: ' ·';
		margin-left: 0.15em;
		opacity: 0.4;
	}

	/* ── Sub & actions ── */
	.hero-sub {
		max-width: 34rem;
		margin-bottom: 2.25rem;
		font-size: clamp(0.95rem, 1.8vw, 1.1rem);
		line-height: 1.7;
		color: var(--hero-muted);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-bottom: 2.75rem;
	}

	.hero-cta {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		border: none;
		border-radius: 999px;
		text-decoration: none;
		font-size: 0.88rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		cursor: pointer;
		transition: transform 0.35s var(--hero-ease);
	}

	.hero-cta:hover {
		transform: translateY(-2px);
	}

	.hero-cta:active {
		transform: translateY(0);
	}

	.hero-cta--primary {
		overflow: hidden;
		background: linear-gradient(135deg, rgba(200, 176, 255, 0.5), rgba(140, 100, 220, 0.5));
		padding: 2px;
		box-shadow: 0 8px 32px rgba(120, 60, 200, 0.35);
	}

	.hero-cta-border {
		position: absolute;
		inset: -50%;
		background: conic-gradient(
			from 0deg,
			transparent 0%,
			rgba(255, 255, 255, 0.9) 12%,
			transparent 24%,
			transparent 100%
		);
		animation: cta-spin 3s linear infinite;
	}

	.hero-cta--primary .hero-cta-inner {
		position: relative;
		z-index: 1;
		padding: 0.85rem 1.75rem;
		border-radius: 999px;
		color: #fff;
		background: linear-gradient(
			135deg,
			rgba(100, 60, 180, 0.95) 0%,
			rgba(70, 40, 140, 0.98) 100%
		);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.15);
	}

	.hero-cta--ghost .hero-cta-inner {
		padding: 0.85rem 1.75rem;
		border-radius: 999px;
		color: var(--hero-text);
		background: var(--hero-glass);
		border: 1px solid var(--hero-glass-border);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		transition:
			background 0.35s ease,
			border-color 0.35s ease,
			box-shadow 0.35s ease;
	}

	.hero-cta--ghost:hover .hero-cta-inner {
		background: rgba(255, 255, 255, 0.1);
		border-color: rgba(200, 176, 255, 0.35);
		box-shadow: 0 0 24px rgba(200, 176, 255, 0.12);
	}

	/* ── Stats ── */
	.hero-stats {
		display: inline-flex;
		align-items: center;
		gap: 1.25rem;
		padding: 0.85rem 1.35rem;
		background: var(--hero-glass);
		border: 1px solid var(--hero-glass-border);
		border-radius: 1rem;
		backdrop-filter: blur(16px) saturate(150%);
		-webkit-backdrop-filter: blur(16px) saturate(150%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.1),
			0 12px 40px rgba(0, 0, 0, 0.25);
	}

	.hero-stat {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.15rem;
		min-width: 3.5rem;
	}

	.hero-stat-value {
		font-size: 1.35rem;
		font-weight: 300;
		letter-spacing: 0.02em;
		color: var(--hero-accent-bright);
		text-shadow: 0 0 20px rgba(200, 176, 255, 0.3);
	}

	.hero-stat-label {
		font-size: 0.65rem;
		font-weight: 500;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--hero-muted);
	}

	.hero-stat-divider {
		width: 1px;
		height: 2rem;
		background: linear-gradient(
			180deg,
			transparent,
			rgba(200, 176, 255, 0.25),
			transparent
		);
	}

	/* ── Scroll cue ── */
	.hero-scroll {
		position: absolute;
		bottom: clamp(1.5rem, 4vh, 2.5rem);
		left: 50%;
		transform: translateX(-50%);
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: var(--hero-muted);
		font-size: 0.65rem;
		font-weight: 500;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		transition: color 0.3s ease;
	}

	.hero-scroll:hover {
		color: var(--hero-accent);
	}

	.hero-scroll-line {
		width: 1px;
		height: 2.5rem;
		background: linear-gradient(
			180deg,
			var(--hero-accent-dim),
			transparent
		);
		position: relative;
		overflow: hidden;
	}

	.hero-scroll-line::after {
		content: '';
		position: absolute;
		top: -100%;
		left: 0;
		width: 100%;
		height: 50%;
		background: var(--hero-accent);
		box-shadow: 0 0 8px var(--hero-accent);
		animation: scroll-drop 2s ease-in-out infinite;
	}

	/* ── Reveal animation ── */
	[data-reveal] {
		opacity: 0;
		transform: translateY(1.5rem);
		transition:
			opacity 0.9s var(--hero-ease) var(--delay, 0s),
			transform 0.9s var(--hero-ease) var(--delay, 0s);
	}

	[data-reveal].is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	/* ── Keyframes ── */
	@keyframes shimmer {
		0%, 100% { background-position: 0% center; }
		50% { background-position: 200% center; }
	}

	@keyframes core-pulse {
		0%, 100% { transform: scale(1); opacity: 1; }
		50% { transform: scale(1.06); opacity: 0.92; }
	}

	@keyframes glow-breathe {
		0%, 100% { transform: scale(1); opacity: 0.8; }
		50% { transform: scale(1.08); opacity: 1; }
	}

	@keyframes orbit-spin {
		to { transform: rotateX(72deg) rotateZ(360deg); }
	}

	.orbit--2 {
		animation-name: orbit-spin-2;
	}

	@keyframes orbit-spin-2 {
		to { transform: rotateX(68deg) rotateZ(-300deg); }
	}

	.orbit--3 {
		animation-name: orbit-spin-3;
	}

	@keyframes orbit-spin-3 {
		to { transform: rotateX(75deg) rotateZ(390deg); }
	}

	@keyframes ray-flicker {
		0%, 100% { opacity: 0.3; }
		50% { opacity: 0.7; }
	}

	@keyframes badge-pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.6; transform: scale(0.85); }
	}

	@keyframes role-cycle {
		0%, 28%, 100% { opacity: 0; transform: translateY(100%); }
		4%, 24% { opacity: 1; transform: translateY(0); }
	}

	@keyframes cta-spin {
		to { transform: rotate(360deg); }
	}

	@keyframes scroll-drop {
		0% { top: -50%; }
		100% { top: 150%; }
	}

	/* ── Responsive ── */
	@media (max-width: 900px) {
		.hero-singularity {
			right: 50%;
			top: 14%;
			transform: translate(calc(50% + var(--parallax-x)), calc(-50% + var(--parallax-y)));
			opacity: 0.45;
			width: clamp(14rem, 70vw, 22rem);
			height: clamp(14rem, 70vw, 22rem);
		}

		.hero-content {
			max-width: none;
			text-align: center;
			margin-inline: auto;
		}

		.hero-badge {
			margin-inline: auto;
		}

		.hero-sub {
			margin-inline: auto;
		}

		.hero-actions {
			justify-content: center;
		}

		.hero-stats {
			margin-inline: auto;
		}

		.hero-roles {
			margin-inline: auto;
			width: fit-content;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-singularity,
		.singularity-core,
		.singularity-glow,
		.orbit,
		.ray,
		.hero-badge-pulse,
		.hero-headline-text,
		.hero-role,
		.hero-cta-border,
		.hero-scroll-line::after {
			animation: none !important;
		}

		.hero-role {
			position: static;
			opacity: 1;
			transform: none;
		}

		.hero-role:not(:first-child) {
			display: none;
		}

		[data-reveal] {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}
</style>
