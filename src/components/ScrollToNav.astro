<button
	type="button"
	class="scroll-to-nav"
	data-scroll-to-nav
	aria-label="Scroll to navigation"
	aria-hidden="true"
>
	<span class="scroll-to-nav__ring" aria-hidden="true"></span>
	<span class="scroll-to-nav__glow" aria-hidden="true"></span>
	<svg class="scroll-to-nav__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
		<path
			d="M12 19V5M5 12l7-7 7 7"
			stroke="currentColor"
			stroke-width="1.5"
			stroke-linecap="round"
			stroke-linejoin="round"
		/>
	</svg>
</button>

<script>
	const button = document.querySelector<HTMLButtonElement>('[data-scroll-to-nav]');
	const navbar = document.querySelector<HTMLElement>('[data-navbar]');

	if (button) {
		const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		const getThreshold = () => navbar?.offsetHeight ?? 96;

		const updateVisibility = () => {
			const show = window.scrollY > getThreshold();
			button.classList.toggle('is-visible', show);
			button.setAttribute('aria-hidden', String(!show));
		};

		button.addEventListener('click', () => {
			window.scrollTo({ top: 0, behavior: prefersReduced ? 'auto' : 'smooth' });
		});

		updateVisibility();
		window.addEventListener('scroll', updateVisibility, { passive: true });
		window.addEventListener('resize', updateVisibility);
	}
</script>

<style>
	.scroll-to-nav {
		--scroll-nav-ease: var(--ease-out);
		position: fixed;
		right: clamp(1rem, 3vw, 1.75rem);
		bottom: clamp(1rem, 3vw, 1.75rem);
		z-index: 90;
		display: grid;
		place-items: center;
		width: 3rem;
		height: 3rem;
		padding: 0;
		border: 1px solid var(--color-glass-border);
		border-radius: 50%;
		color: var(--color-text-primary);
		background: var(--color-glass);
		backdrop-filter: blur(16px) saturate(150%);
		-webkit-backdrop-filter: blur(16px) saturate(150%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.1),
			0 12px 32px rgba(0, 0, 0, 0.35);
		cursor: pointer;
		opacity: 0;
		visibility: hidden;
		transform: translate3d(0, 14px, 0) scale(0.92);
		pointer-events: none;
		transition:
			opacity 0.35s var(--scroll-nav-ease),
			visibility 0.35s var(--scroll-nav-ease),
			transform 0.35s var(--scroll-nav-ease),
			border-color 0.25s ease,
			box-shadow 0.35s ease,
			color 0.25s ease;
	}

	.scroll-to-nav.is-visible {
		opacity: 1;
		visibility: visible;
		transform: translate3d(0, 0, 0) scale(1);
		pointer-events: auto;
	}

	.scroll-to-nav__ring {
		position: absolute;
		inset: -2px;
		border-radius: inherit;
		padding: 1px;
		background: conic-gradient(
			from 0deg,
			transparent 0deg,
			rgba(200, 176, 255, 0.5) 90deg,
			transparent 180deg,
			rgba(200, 176, 255, 0.35) 270deg,
			transparent 360deg
		);
		-webkit-mask:
			linear-gradient(#fff 0 0) content-box,
			linear-gradient(#fff 0 0);
		mask:
			linear-gradient(#fff 0 0) content-box,
			linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
		opacity: 0;
		transition: opacity 0.3s ease;
		animation: scroll-to-nav-ring 6s linear infinite;
	}

	.scroll-to-nav__glow {
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background: radial-gradient(circle, rgba(200, 176, 255, 0.2) 0%, transparent 70%);
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.scroll-to-nav__icon {
		position: relative;
		z-index: 1;
		width: 1.15rem;
		height: 1.15rem;
		transition: transform 0.35s var(--scroll-nav-ease);
	}

	.scroll-to-nav:hover,
	.scroll-to-nav:focus-visible {
		color: var(--color-accent-bright);
		border-color: var(--color-glass-border-accent);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.14),
			0 16px 40px rgba(100, 64, 180, 0.3);
	}

	.scroll-to-nav:hover .scroll-to-nav__ring,
	.scroll-to-nav:focus-visible .scroll-to-nav__ring,
	.scroll-to-nav.is-visible .scroll-to-nav__ring {
		opacity: 1;
	}

	.scroll-to-nav:hover .scroll-to-nav__glow,
	.scroll-to-nav:focus-visible .scroll-to-nav__glow {
		opacity: 1;
	}

	.scroll-to-nav:hover .scroll-to-nav__icon,
	.scroll-to-nav:focus-visible .scroll-to-nav__icon {
		transform: translateY(-2px);
	}

	@keyframes scroll-to-nav-ring {
		to {
			transform: rotate(360deg);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.scroll-to-nav,
		.scroll-to-nav.is-visible {
			transition: none;
		}

		.scroll-to-nav__ring {
			animation: none;
		}
	}
</style>
